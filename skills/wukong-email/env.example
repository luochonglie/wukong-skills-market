# Wukong Email Toolkit - environment variable template
# ====================================
# Copy this file to ~/.wukong-email/.env and fill in your actual settings
#
# Config precedence:
#   system environment variables > ~/.wukong-email/.env file > code defaults

# ═══════════════════════════════════════════════════════════
# 📧 Mailbox credentials (required)
# ═══════════════════════════════════════════════════════════
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_FROM_NAME=

# ═══════════════════════════════════════════════════════════
# 📤 SMTP configuration (sending email)
# ═══════════════════════════════════════════════════════════
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USE_SSL=true

# SMTP SSL configuration (use for self-signed or private-CA certificates when needed)
EMAIL_SMTP_SSL_VERIFY=false
EMAIL_SMTP_SSL_CIPHERS=ECDHE-RSA-AES256-GCM-SHA384:AES256-GCM-SHA384

# ═══════════════════════════════════════════════════════════
# 📥 IMAP configuration (receiving email)
# ═══════════════════════════════════════════════════════════
EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USE_SSL=true

# IMAP SSL configuration (use for self-signed or private-CA certificates when needed)
EMAIL_IMAP_SSL_VERIFY=false
EMAIL_IMAP_SSL_CIPHERS=ECDHE-RSA-AES256-GCM-SHA384:AES256-GCM-SHA384

# ═══════════════════════════════════════════════════════════
# 📁 Sent folder configuration
# ═══════════════════════════════════════════════════════════
# Whether to save to the Sent folder after sending (default: true)
EMAIL_ENABLE_SAVE_TO_SENT=true

# Sent folder name (use a friendly name, no encoding needed)
# Supported friendly names:
#   - English: Sent, Sent Items, Sent Messages
#   - Chinese: 已发送, 已发送邮件, 发件箱
# The system auto-converts it to IMAP UTF-7 encoding
EMAIL_SENT_FOLDER=Sent

# ═══════════════════════════════════════════════════════════
# 📎 Attachment download directory
# ═══════════════════════════════════════════════════════════
EMAIL_ATTACHMENTS_DIR=~/.wukong-email/attachments

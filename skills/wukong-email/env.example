# 悟空邮件工具包 - 环境变量配置模板
# ====================================
# 复制此文件为 ~/.wukong-email/.env 并填入您的实际配置
#
# 配置优先级：
#   系统环境变量 > ~/.wukong-email/.env 文件 > 代码默认值

# ═══════════════════════════════════════════════════════════
# 📧 邮箱凭据（必需）
# ═══════════════════════════════════════════════════════════
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_FROM_NAME=

# ═══════════════════════════════════════════════════════════
# 📤 SMTP 配置（发送邮件）
# ═══════════════════════════════════════════════════════════
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USE_SSL=true

# SMTP SSL 配置（需要时可用于自签名或私有 CA 证书）
EMAIL_SMTP_SSL_VERIFY=false
EMAIL_SMTP_SSL_CIPHERS=ECDHE-RSA-AES256-GCM-SHA384:AES256-GCM-SHA384

# ═══════════════════════════════════════════════════════════
# 📥 IMAP 配置（接收邮件）
# ═══════════════════════════════════════════════════════════
EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USE_SSL=true

# IMAP SSL 配置（需要时可用于自签名或私有 CA 证书）
EMAIL_IMAP_SSL_VERIFY=false
EMAIL_IMAP_SSL_CIPHERS=ECDHE-RSA-AES256-GCM-SHA384:AES256-GCM-SHA384

# ═══════════════════════════════════════════════════════════
# 📁 已发送文件夹配置
# ═══════════════════════════════════════════════════════════
# 是否在发送后保存到已发送文件夹（默认：true）
EMAIL_ENABLE_SAVE_TO_SENT=true

# 已发送文件夹名称（使用友好名称，无需编码）
# 支持的友好名称：
#   - 中文：已发送、已发送邮件、发件箱
#   - 英文：Sent、Sent Items，Sent Messages
# 系统会自动转换为 IMAP UTF-7 编码
EMAIL_SENT_FOLDER=已发送

# ═══════════════════════════════════════════════════════════
# 📎 附件下载目录配置
# ═══════════════════════════════════════════════════════════
EMAIL_ATTACHMENTS_DIR=~/.wukong-email/attachments
